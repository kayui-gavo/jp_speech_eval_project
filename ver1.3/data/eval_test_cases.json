{
  "metadata": {
    "name": "jp_speech_eval_core_test_cases",
    "purpose": "Small fixed-reference and diagnostic utterance set for product guardrails.",
    "notes": "These are test targets, not a complete curriculum. Pitch-accent items require verified target data before strong user-facing feedback."
  },
  "cases": [
